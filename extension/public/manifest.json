{
  "manifest_version": 3,
  "name": "GitHub Repo Q&A",
  "version": "1.0.0",
  "description": "Ask questions about any GitHub repository using AI-powered RAG",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:8000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
